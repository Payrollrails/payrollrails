# Stellar Network
STELLAR_NETWORK=testnet
# STELLAR_NETWORK=mainnet

# Horizon RPC
HORIZON_URL=https://horizon-testnet.stellar.org
# HORIZON_URL=https://horizon.stellar.org

# Soroban RPC (for voucher contract)
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Funding wallet (source of USDC payments)
# Generate at: https://laboratory.stellar.org/#account-creator?network=test
FUNDER_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Fee-bump account (pays base fees)
FEE_BUMP_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# USDC asset issuer (Testnet: Centre/Circle test issuer)
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# SQLite DB path
DB_PATH=./data/payrollrails.db

# Server port
PORT=3001

# Deployed voucher contract ID (after deploying contracts/voucher)
VOUCHER_CONTRACT_ID=

# Optional: email→address resolver (stub by default)
EMAIL_RESOLVER_URL=
